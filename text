// Order Scene
const orderScene = new Scenes.WizardScene(
  'ORDER_SCENE',
  async (ctx) => {
    const serviceId = ctx.scene.state.serviceId;
    const service = await dbGet(`SELECT * FROM services WHERE id = ?`, [serviceId]);

    if (!service) {
      await ctx.reply('Xizmat topilmadi.', userMainKeyboard());
      return ctx.scene.leave();
    }

    ctx.scene.state.service = service;
    ctx.scene.state.fields = JSON.parse(service.required_fields || '[]');
    ctx.scene.state.responses = {};
    ctx.scene.state.currentFieldIndex = 0;

    if (ctx.scene.state.fields.length === 0) {
      let summary = `📋 *Buyurtmani tasdiqlang:*\n\n`;
      summary += `🔹 *Xizmat:* ${service.title}\n`;
      summary += `💰 *Narxi:* ${formatPrice(service.price)}\n\n`;
      summary += `Barcha ma'lumotlar to'g'rimi?`;

      await ctx.replyWithMarkdown(summary, Markup.inlineKeyboard([
        [Markup.button.callback('✅ Tasdiqlash', 'CONFIRM_ORDER')],
        [Markup.button.callback('❌ Bekor qilish', 'CANCEL_ORDER_SCENE')]
      ]));
      return ctx.wizard.selectStep(2);
    }

    const field = ctx.scene.state.fields[0];
    const prompts = {
      username: '👤 Telegram username yoki ID yuboring (masalan: @username):',
      link: '🔗 Havola (link) yuboring:',
      quantity: '🔢 Miqdorni kiriting:',
      note: '📝 Qo‘shimcha eslatma yozing (ixtiyoriy):'
    };

    await ctx.reply(
      prompts[field] || `Iltimos, ${field} ma'lumotini yuboring:`,
      Markup.keyboard([['❌ Bekor qilish']]).resize()
    );
    return ctx.wizard.next();
  },

  async (ctx) => {
    if (ctx.message?.text === '❌ Bekor qilish') {
      await ctx.reply('Buyurtma bekor qilindi.', userMainKeyboard());
      return ctx.scene.leave();
    }

    if (!ctx.message?.text) {
      await ctx.reply("Iltimos, matn ko‘rinishida ma'lumot yuboring.");
      return;
    }

    const fields = ctx.scene.state.fields;
    const index = ctx.scene.state.currentFieldIndex;

    ctx.scene.state.responses[fields[index]] = ctx.message.text;
    ctx.scene.state.currentFieldIndex++;

    if (ctx.scene.state.currentFieldIndex < fields.length) {
      const nextField = fields[ctx.scene.state.currentFieldIndex];
      const prompts = {
        username: '👤 Telegram username yoki ID yuboring:',
        link: '🔗 Havola yuboring:',
        quantity: '🔢 Miqdorni kiriting:',
        note: '📝 Eslatma:'
      };

      await ctx.reply(prompts[nextField] || `Iltimos, ${nextField} ma'lumotini yuboring:`);
      return;
    }

    const service = ctx.scene.state.service;
    let summary = `📋 *Buyurtmani tasdiqlang:*\n\n`;
    summary += `🔹 *Xizmat:* ${service.title}\n`;
    summary += `💰 *Narxi:* ${formatPrice(service.price)}\n`;

    for (const [k, v] of Object.entries(ctx.scene.state.responses)) {
      summary += `🔸 *${k}:* ${v}\n`;
    }

    summary += `\nBarcha ma'lumotlar to'g'rimi?`;

    await ctx.replyWithMarkdown(summary, Markup.inlineKeyboard([
      [Markup.button.callback('✅ Tasdiqlash', 'CONFIRM_ORDER')],
      [Markup.button.callback('❌ Bekor qilish', 'CANCEL_ORDER_SCENE')]
    ]));

    return ctx.wizard.next();
  },

  async () => {
    // action orqali handled
  }
);

orderScene.action('CONFIRM_ORDER', async (ctx) => {
  const { service, responses } = ctx.scene.state;
  const userId = ctx.from.id;

  const result = await dbRun(
    `INSERT INTO orders (user_id, service_id, service_title, amount, status, details, updated_at) 
     VALUES (?, ?, ?, ?, ?, ?, CURRENT_TIMESTAMP)`,
    [userId, service.id, service.title, service.price, 'To‘lov kutilmoqda', JSON.stringify(responses)]
  );

  const orderId = result.lastID;

  await ctx.answerCbQuery('Buyurtma qabul qilindi!');
  await ctx.editMessageText(
    `✅ *Buyurtma yaratildi!*\n\nID: #${orderId}\nXizmat: ${service.title}\nNarxi: ${formatPrice(service.price)}\nHolat: To‘lov kutilmoqda\n\nTo'lov qilish uchun "💳 To‘lov qilish" bo'limiga o'ting.`,
    { parse_mode: 'Markdown' }
  );

  for (const adminId of ADMIN_IDS) {
    try {
      await ctx.telegram.sendMessage(
        adminId,
        `🆕 *Yangi buyurtma!*\n\nID: #${orderId}\nMijoz: ${ctx.from.first_name} (@${ctx.from.username || 'yoq'})\nXizmat: ${service.title}\nNarxi: ${formatPrice(service.price)}`,
        { parse_mode: 'Markdown' }
      );
    } catch (e) {}
  }

  await ctx.reply('Asosiy menyu:', userMainKeyboard());
  return ctx.scene.leave();
});

orderScene.action('CANCEL_ORDER_SCENE', async (ctx) => {
  await ctx.answerCbQuery('Bekor qilindi');
  await ctx.editMessageText('❌ Buyurtma bekor qilindi.');
  await ctx.reply('Asosiy menyu:', userMainKeyboard());
  return ctx.scene.leave();
});

// Payment Scene
const paymentScene = new Scenes.WizardScene(
  'PAYMENT_SCENE',
  async (ctx) => {
    const orders = await dbQuery(
      `SELECT * FROM orders WHERE user_id = ? AND status = 'To‘lov kutilmoqda' ORDER BY id DESC`,
      [ctx.from.id]
    );

    if (orders.length === 0) {
      await ctx.reply("Sizda to‘lanishi kutilayotgan buyurtmalar yo‘q.", userMainKeyboard());
      return ctx.scene.leave();
    }

    ctx.scene.state.orders = orders;
    const buttons = orders.map(o => [
      Markup.button.callback(`#${o.id} - ${o.service_title}`, `SELECT_ORDER_${o.id}`)
    ]);

    await ctx.reply("💳 Qaysi buyurtma uchun to‘lov qilmoqchisiz?\n\n", Markup.inlineKeyboard(buttons));
    return ctx.wizard.next();
  },

  async () => {
    // action orqali handled
  },

  async (ctx) => {
    if (ctx.message?.text === '❌ Bekor qilish') {
      await ctx.reply('Bekor qilindi.', userMainKeyboard());
      return ctx.scene.leave();
    }

    if (ctx.message?.photo) {
      const fileId = ctx.message.photo[ctx.message.photo.length - 1].file_id;
      const orderId = ctx.scene.state.selectedOrderId;

      await dbRun(
        `INSERT INTO payments (order_id, user_id, method, amount, receipt_file_id) VALUES (?, ?, ?, ?, ?)`,
        [orderId, ctx.from.id, ctx.scene.state.methodTitle, ctx.scene.state.orderAmount, fileId]
      );

      await dbRun(
        `UPDATE orders SET status = 'To‘lov tekshirilmoqda', updated_at = CURRENT_TIMESTAMP WHERE id = ?`,
        [orderId]
      );

      await ctx.reply(
        "✅ To‘lov ma’lumotingiz qabul qilindi. Admin tekshirganidan so‘ng sizga xabar beriladi.",
        userMainKeyboard()
      );

      for (const adminId of ADMIN_IDS) {
        try {
          await ctx.telegram.sendPhoto(adminId, fileId, {
            caption:
              `💰 *Yangi to‘lov!*\n\n` +
              `Buyurtma ID: #${orderId}\n` +
              `Mijoz: ${ctx.from.first_name} (@${ctx.from.username || 'yoq'})\n` +
              `Summa: ${formatPrice(ctx.scene.state.orderAmount)}`,
            parse_mode: 'Markdown',
            reply_markup: Markup.inlineKeyboard([
              [
                Markup.button.callback('✅ Tasdiqlash', `APPROVE_PAY_${orderId}`),
                Markup.button.callback('❌ Rad etish', `REJECT_PAY_${orderId}`)
              ]
            ]).reply_markup
          });
        } catch (e) {}
      }

      return ctx.scene.leave();
    }

    await ctx.reply(
      'Iltimos, to‘lov cheki rasmini yuboring.',
      Markup.keyboard([['❌ Bekor qilish']]).resize()
    );
  }
);

paymentScene.action(/^SELECT_ORDER_(\d+)$/, async (ctx) => {
  const orderId = parseInt(ctx.match[1], 10);
  const order = await dbGet(`SELECT * FROM orders WHERE id = ?`, [orderId]);

  if (!order || order.user_id !== ctx.from.id) {
    await ctx.answerCbQuery('Buyurtma topilmadi');
    return;
  }

  ctx.scene.state.selectedOrderId = orderId;
  ctx.scene.state.orderAmount = order.amount;

  const methods = await dbQuery(`SELECT * FROM payment_methods WHERE is_active = 1`);
  if (methods.length === 0) {
    await ctx.editMessageText("Hozircha to‘lov usullari mavjud emas. Admin bilan bog‘laning.");
    return ctx.scene.leave();
  }

  const buttons = methods.map(m => [Markup.button.callback(m.title, `METHOD_${m.id}`)]);
  await ctx.editMessageText('💳 To‘lov usulini tanlang:\n\n', Markup.inlineKeyboard(buttons));
});

paymentScene.action(/^METHOD_(\d+)$/, async (ctx) => {
  const methodId = parseInt(ctx.match[1], 10);
  const method = await dbGet(`SELECT * FROM payment_methods WHERE id = ?`, [methodId]);

  if (!method) {
    await ctx.answerCbQuery('To‘lov usuli topilmadi');
    return;
  }

  ctx.scene.state.methodTitle = method.title;

  let msg = `💳 *${method.title}*\n\n`;
  msg += `${method.details}\n\n`;
  msg += `💰 To‘lov miqdori: *${formatPrice(ctx.scene.state.orderAmount)}*\n\n`;
  msg += `📸 To‘lov qilganingizdan so‘ng, chek rasmini (skrinshot) yuboring:`;

  await ctx.editMessageText(msg, { parse_mode: 'Markdown' });
  await ctx.reply(
    'Chek rasmini yuboring:',
    Markup.keyboard([['❌ Bekor qilish']]).resize()
  );
  return ctx.wizard.selectStep(2);
});

// Broadcast Scene
const broadcastScene = new Scenes.WizardScene(
  'BROADCAST_SCENE',
  async (ctx) => {
    await ctx.reply(
      '📣 Reklama xabarini yuboring (matn, rasm yoki video):',
      Markup.keyboard([['❌ Bekor qilish']]).resize()
    );
    return ctx.wizard.next();
  },

  async (ctx) => {
    if (ctx.message?.text === '❌ Bekor qilish') {
      await ctx.reply('Bekor qilindi.', adminMainKeyboard());
      return ctx.scene.leave();
    }

    ctx.scene.state.broadcastMsg = ctx.message;

    await ctx.reply(
      'Xabar barcha foydalanuvchilarga yuborilsinmi?',
      Markup.inlineKeyboard([
        [Markup.button.callback('✅ Ha, yuborish', 'CONFIRM_BROADCAST')],
        [Markup.button.callback('❌ Yo‘q', 'CANCEL_BROADCAST')]
      ])
    );
    return ctx.wizard.next();
  }
);

broadcastScene.action('CONFIRM_BROADCAST', async (ctx) => {
  const msg = ctx.scene.state.broadcastMsg;
  const users = await dbQuery(`SELECT telegram_id FROM users`);
  let success = 0;
  let fail = 0;

  await ctx.editMessageText('⏳ Yuborilmoqda...');

  for (const user of users) {
    try {
      await ctx.telegram.copyMessage(user.telegram_id, ctx.chat.id, msg.message_id);
      success++;
    } catch (e) {
      fail++;
    }
  }

  await ctx.reply(
    `✅ Tugatildi!\n\nSoni: ${users.length}\nMuvaffaqiyatli: ${success}\nXato: ${fail}`,
    adminMainKeyboard()
  );
  return ctx.scene.leave();
});

broadcastScene.action('CANCEL_BROADCAST', async (ctx) => {
  await ctx.editMessageText('❌ Bekor qilindi.');
  await ctx.reply('Admin menyu:', adminMainKeyboard());
  return ctx.scene.leave();
});

const scenes = new Scenes.Stage([orderScene, paymentScene, broadcastScene]);
botInstance.use(session());
botInstance.use(scenes.middleware());

botInstance.use(async (ctx, next) => {
  try {
    await saveUser(ctx);
  } catch (e) {
    console.error('saveUser error:', e);
  }
  return next();
});

