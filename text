botInstance.hears('📊 Statistika', async (ctx) => {
  if (!isAdmin(ctx)) return;

  const users = await dbGet(`SELECT COUNT(*) as count FROM users`);
  const orders = await dbGet(`SELECT COUNT(*) as count FROM orders`);
  const pendingOrders = await dbGet(`SELECT COUNT(*) as count FROM orders WHERE status = 'Yangi' OR status = 'To‘lov kutilmoqda'`);
  const pendingPayments = await dbGet(`SELECT COUNT(*) as count FROM orders WHERE status = 'To‘lov tekshirilmoqda'`);
  const completedOrders = await dbGet(`SELECT COUNT(*) as count FROM orders WHERE status = 'Bajarildi'`);

  let msg = `📊 *Bot statistikasi:*\n\n`;
  msg += `👥 Jami foydalanuvchilar: ${users?.count || 0}\n`;
  msg += `📦 Jami buyurtmalar: ${orders?.count || 0}\n`;
  msg += `⏳ Kutilayotgan buyurtmalar: ${pendingOrders?.count || 0}\n`;
  msg += `💰 Tasdiqlash kutilayotgan to‘lovlar: ${pendingPayments?.count || 0}\n`;
  msg += `✅ Bajarilgan buyurtmalar: ${completedOrders?.count || 0}\n`;

  await ctx.replyWithMarkdown(msg);
});

botInstance.hears('📦 Buyurtmalar', async (ctx) => {
  if (!isAdmin(ctx)) return;

  const orders = await dbQuery(`SELECT * FROM orders WHERE status != 'Bajarildi' AND status != 'Bekor qilindi' ORDER BY id DESC LIMIT 20`);
  if (orders.length === 0) return ctx.reply("Hozircha faol buyurtmalar yo'q.");

  for (const o of orders) {
    let detailsText = o.details;
    try {
      const parsed = JSON.parse(o.details || '{}');
      detailsText = Object.entries(parsed).map(([k, v]) => `${k}: ${v}`).join('\n');
    } catch (e) {}

    let msg = `🆔 *Buyurtma #${o.id}*\n`;
    msg += `👤 Mijoz ID: ${o.user_id}\n`;
    msg += `📦 Xizmat: ${o.service_title}\n`;
    msg += `💰 Summa: ${formatPrice(o.amount)}\n`;
    msg += `🏷 Holat: ${o.status}\n`;
    msg += `📝 Tafsilotlar: ${detailsText || '-'}\n`;

    await ctx.replyWithMarkdown(msg, Markup.inlineKeyboard([
      [Markup.button.callback('🚀 Ishni boshlash', `START_WORK_${o.id}`)],
      [Markup.button.callback('🏁 Bajarildi', `COMPLETE_ORDER_${o.id}`)],
      [Markup.button.callback('🛑 Bekor qilish', `ADMIN_CANCEL_ORDER_${o.id}`)]
    ]));
  }
});

botInstance.action(/^START_WORK_(\d+)$/, async (ctx) => {
  if (!isAdmin(ctx)) return;

  const orderId = ctx.match[1];
  await dbRun(`UPDATE orders SET status = 'Jarayonda', updated_at = CURRENT_TIMESTAMP WHERE id = ?`, [orderId]);
  const order = await dbGet(`SELECT user_id FROM orders WHERE id = ?`, [orderId]);

  await ctx.answerCbQuery('Ish boshlandi');

  try {
    await ctx.editMessageText(`${ctx.callbackQuery.message.text}\n\n🚀 Holat: Jarayonda`);
  } catch (e) {}

  try {
    await ctx.telegram.sendMessage(order.user_id, `🚀 Buyurtmangiz (#${orderId}) jarayonga tushdi!`);
  } catch (e) {}
});

