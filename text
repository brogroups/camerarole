  if (orders.length === 0) {
    return ctx.reply("Sizda hali buyurtmalar yo'q.");
  }

  let msg = '📦 *Oxirgi buyurtmalaringiz:*\n\n';
  orders.forEach(o => {
    msg += `🆔 #${o.id} | ${o.service_title}\n`;
    msg += `💰 ${formatPrice(o.amount)} | 🏷 ${o.status}\n`;
    msg += `📅 ${new Date(o.created_at).toLocaleString('uz-UZ')}\n\n`;
  });

  await ctx.replyWithMarkdown(msg);
});

