import { Telegraf, Scenes, session, Markup } from 'telegraf';
import sqlite3 from 'sqlite3';
import dotenv from 'dotenv';

dotenv.config();

// --- CONFIGURATION ---
const BOT_TOKEN = process.env.BOT_TOKEN;
const ADMIN_IDS = process.env.ADMIN_ID
  ? process.env.ADMIN_ID.split(',').map(id => parseInt(id.trim(), 10)).filter(Boolean)
  : [];
const DB_PATH = './bot_database.sqlite';

if (!BOT_TOKEN) {
  console.error('CRITICAL ERROR: BOT_TOKEN is missing in .env');
  process.exit(1);
}

// --- DATABASE SETUP ---
const db = new sqlite3.Database(DB_PATH);

function dbRun(sql, params = []) {
  return new Promise((resolve, reject) => {
    db.run(sql, params, function (err) {
      if (err) return reject(err);
      resolve({
        lastID: this.lastID,
        changes: this.changes,
      });
    });
  });
}

function dbGet(sql, params = []) {
  return new Promise((resolve, reject) => {
    db.get(sql, params, (err, row) => {
      if (err) return reject(err);
      resolve(row);
    });
  });
}

function dbQuery(sql, params = []) {
  return new Promise((resolve, reject) => {
    db.all(sql, params, (err, rows) => {
      if (err) return reject(err);
      resolve(rows || []);
    });
  });
}

// --- HELPERS ---
function formatPrice(price) {
  const amount = Number(price || 0);
  return `${amount.toLocaleString('uz-UZ')} so'm`;
}

function isAdmin(ctx) {
  return ADMIN_IDS.includes(ctx.from?.id);
}

function userMainKeyboard() {
  return Markup.keyboard([
    ['🛍 Xizmatlar', '💳 To‘lov qilish'],
    ['📦 Buyurtmalarim', '📩 Admin bilan bog‘lanish'],
    ['💎 Telegram Premium', '⭐ Telegram Stars'],
    ['ℹ️ Qoidalar', '❓ Yordam']
  ]).resize();
}

function adminMainKeyboard() {
  return Markup.keyboard([
    ['📊 Statistika', '📦 Buyurtmalar'],
    ['📣 Xabar yuborish', '❌ Yopish']
  ]).resize();
}

async function getSetting(key) {
  const row = await dbGet(`SELECT value FROM settings WHERE key = ?`, [key]);
  return row?.value || '';
}

async function saveUser(ctx) {
  if (!ctx.from || ctx.chat?.type !== 'private') return;

  const telegramId = ctx.from.id;
  const username = ctx.from.username || null;
  const firstName = ctx.from.first_name || 'Foydalanuvchi';

  const existing = await dbGet(`SELECT telegram_id FROM users WHERE telegram_id = ?`, [telegramId]);

  if (existing) {
    await dbRun(
      `UPDATE users
       SET username = ?, first_name = ?, last_active = CURRENT_TIMESTAMP
       WHERE telegram_id = ?`,
      [username, firstName, telegramId]
    );
  } else {
    await dbRun(
      `INSERT INTO users (telegram_id, username, first_name, last_active)
       VALUES (?, ?, ?, CURRENT_TIMESTAMP)`,
      [telegramId, username, firstName]
    );
  }
}

