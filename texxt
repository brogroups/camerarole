bot.action(/^APPROVE_PAY_(\d+)$/, async (ctx) => {
  if (!isAdmin(ctx)) return;

  const orderId = Number(ctx.match[1]);
  const order = findOrderById(orderId);
  if (!order) {
    await ctx.answerCbQuery('Buyurtma topilmadi.');
    return;
  }

  const payment = findPaymentByOrderId(orderId);
  if (payment) payment.status = PAYMENT_STATUS.APPROVED;
  order.status = ORDER_STATUS.CONFIRMED;
  order.updated_at = nowIso();

  await saveData();
  await logAction('PAYMENT_APPROVED', `order_id=${orderId}`);

  await ctx.answerCbQuery('Tasdiqlandi');
  try {
    await ctx.editMessageReplyMarkup({ reply_markup: buildOrderAdminActions(orderId).reply_markup });
  } catch {}

  try {
    await ctx.telegram.sendMessage(order.user_id, `✅ To‘lovingiz tasdiqlandi. Buyurtmangiz (#${orderId}) tez orada ishga olinadi.`);
  } catch {}
});

