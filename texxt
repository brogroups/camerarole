async function saveUser(ctx) {
  if (!ctx.from || ctx.chat?.type !== 'private') return;

  const telegramId = Number(ctx.from.id);
  const user = findUserByTelegramId(telegramId);

  if (user) {
    user.first_name = ctx.from.first_name || user.first_name || 'Foydalanuvchi';
    user.last_name = ctx.from.last_name || user.last_name || '';
    user.username = ctx.from.username || user.username || null;
    user.last_active = nowIso();
  } else {
    ensureTable('users').push({
      telegram_id: telegramId,
      first_name: ctx.from.first_name || 'Foydalanuvchi',
      last_name: ctx.from.last_name || '',
      username: ctx.from.username || null,
      role: isAdmin(ctx) ? 'admin' : 'user',
      is_banned: 0,
      join_date: nowIso(),
      last_active: nowIso(),
    });
  }

  await saveData();
}

