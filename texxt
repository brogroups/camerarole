const settingsEditScene = new Scenes.WizardScene(
  'SETTINGS_EDIT_SCENE',
  async (ctx) => {
    const mode = ctx.scene.state.mode;

    const prompts = {
      welcome_text: 'Yangi welcome matnini yuboring.',
      faq_text: 'Yangi yordam matnini yuboring.',
      rules_text: 'Yangi qoidalar matnini yuboring.',
      support_username: 'Yangi admin username yuboring. Masalan: @your_username',
      add_force_channel: 'Kanal username yuboring. Masalan: @kanalnomi',
      remove_force_channel: 'O‘chiriladigan kanal username yuboring. Masalan: @kanalnomi',
    };

    await ctx.reply(prompts[mode] || 'Yangi qiymatni yuboring.', Markup.keyboard([['❌ Bekor qilish']]).resize());
    return ctx.wizard.next();
  },
  async (ctx) => {
    if (ctx.message?.text === '❌ Bekor qilish') {
      await ctx.reply('Bekor qilindi.', adminMainKeyboard());
      return ctx.scene.leave();
    }

    if (!ctx.message?.text) {
      await ctx.reply('Iltimos, matn yuboring.');
      return;
    }

    const mode = ctx.scene.state.mode;
    const value = safeText(ctx.message.text);

    if (mode === 'support_username') {
      if (!/^@?[a-zA-Z0-9_]{5,32}$/.test(value)) {
        await ctx.reply('Username noto‘g‘ri. Masalan: @admin_username');
        return;
      }
      await setSetting('support_username', cleanSupportUsername(value));
      await ctx.reply('✅ Admin username yangilandi.', adminMainKeyboard());
      return ctx.scene.leave();
    }

    if (mode === 'add_force_channel') {
      if (!/^@?[a-zA-Z0-9_]{5,}$/.test(value)) {
        await ctx.reply('Kanal username noto‘g‘ri. Masalan: @kanal');
        return;
      }

      const username = cleanSupportUsername(value);
      const list = await getForceJoinChannels();
      const exists = list.some((item) => cleanSupportUsername(item.username) === username);
      if (exists) {
        await ctx.reply('Bu kanal allaqachon qo‘shilgan.', adminMainKeyboard());
        return ctx.scene.leave();
      }

      list.push({ username, title: `@${username}`, chat_id: `@${username}` });
      await setSetting('force_join_channels', list);
      await ctx.reply('✅ Kanal qo‘shildi.', adminMainKeyboard());
      return ctx.scene.leave();
    }

    if (mode === 'remove_force_channel') {
      const username = cleanSupportUsername(value);
      const list = await getForceJoinChannels();
      const filtered = list.filter((item) => cleanSupportUsername(item.username) !== username);
      await setSetting('force_join_channels', filtered);
      await ctx.reply('✅ Kanal o‘chirildi.', adminMainKeyboard());
      return ctx.scene.leave();
    }

    if (['welcome_text', 'faq_text', 'rules_text'].includes(mode)) {
      await setSetting(mode, value);
      await ctx.reply('✅ Matn yangilandi.', adminMainKeyboard());
      return ctx.scene.leave();
    }
  }
);

