async function getForceJoinChannels() {
  const value = getSetting('force_join_channels', []);
  return Array.isArray(value) ? value : [];
}

async function isForceJoinPassed(ctx) {
  if (!getSetting('force_join_enabled', false)) return true;

  const channels = await getForceJoinChannels();
  if (!channels.length) return true;

  for (const item of channels) {
    const chatId = item.chat_id || item.username;
    if (!chatId) continue;

    try {
      const member = await ctx.telegram.getChatMember(chatId, ctx.from.id);
      const status = member?.status;
      const ok = ['creator', 'administrator', 'member'].includes(status);
      if (!ok) return false;
    } catch {
      return false;
    }
  }

  return true;
}

async function showForceJoinMessage(ctx) {
  const channels = await getForceJoinChannels();
  const buttons = [];

  for (const item of channels) {
    if (item.username) {
      buttons.push([Markup.button.url(item.title || `@${item.username}`, `https://t.me/${String(item.username).replace(/^@/, '')}`)]);
    }
  }

  buttons.push([Markup.button.callback('✅ Tekshirish', 'CHECK_FORCE_JOIN')]);

  const text =
    '📢 Botdan foydalanish uchun avval quyidagi kanal(lar)ga obuna bo‘ling, so‘ng "Tekshirish" tugmasini bosing.';

  if (ctx.callbackQuery) {
    try {
      await ctx.editMessageText(text, { reply_markup: Markup.inlineKeyboard(buttons).reply_markup });
      return;
    } catch {}
  }

  await ctx.reply(text, { reply_markup: Markup.inlineKeyboard(buttons).reply_markup });
}

async function guardPrivateAndSubscribed(ctx, next) {
  if (!ctx.from) return;
  if (ctx.chat?.type && ctx.chat.type !== 'private') return;

  const passed = await isForceJoinPassed(ctx);
  if (!passed) {
    if (ctx.callbackQuery) {
      try {
        await ctx.answerCbQuery('Avval kanalga obuna bo‘ling.', { show_alert: true });
      } catch {}
    }
    await showForceJoinMessage(ctx);
    return;
  }

  return next();
}

function buildPaymentMethodsInline(prefix, includeCancel = true) {
  const methods = ensureTable('payment_methods').filter((m) => Number(m.is_active) === 1);
  const buttons = methods.map((m) => [Markup.button.callback(m.title, `${prefix}${m.id}`)]);
  if (includeCancel) buttons.push([Markup.button.callback('❌ Bekor qilish', 'CANCEL_ORDER_SCENE')]);
  return Markup.inlineKeyboard(buttons);
}

function formatOrderDetails(details) {
  if (!details) return '-';
  try {
    const parsed = typeof details === 'string' ? JSON.parse(details) : details;
    return Object.entries(parsed)
      .map(([k, v]) => `• ${k}: ${v}`)
      .join('\n');
  } catch {
    return String(details);
  }
}

const bot = new Telegraf(BOT_TOKEN);

const orderScene = new Scenes.WizardScene(
  'ORDER_SCENE',
  async (ctx) => {
    const serviceId = Number(ctx.scene.state.serviceId);
    const service = findServiceById(serviceId);

    if (!service || Number(service.is_active) !== 1) {
      await ctx.reply('Xizmat topilmadi.', userMainKeyboard(isAdmin(ctx)));
      return ctx.scene.leave();
    }

    ctx.scene.state.service = clone(service);
    ctx.scene.state.responses = {};
    ctx.scene.state.fields = Array.isArray(service.required_fields)
      ? clone(service.required_fields)
      : [];
    ctx.scene.state.currentFieldIndex = 0;

    if (Number(service.price) <= 0) {
      ctx.scene.state.fields = ['note'];
    }

    const info = [];
    info.push(`📦 Xizmat: ${service.title}`);
    info.push(`📝 ${service.description || '-'}`);
    info.push(`💰 Narx: ${service.price > 0 ? formatPrice(service.price) : 'Kelishiladi'}`);
    info.push(`⏱ Muddat: ${service.delivery_time || '-'}`);
    if (service.notes) info.push(`ℹ️ ${service.notes}`);

    await ctx.reply(info.join('\n'), Markup.keyboard([['❌ Bekor qilish']]).resize());

    const field = ctx.scene.state.fields[0];
    const prompts = {
      username: '👤 Telegram username yuboring. Masalan: @username',
      link: '🔗 Havola yuboring.',
      note: '📝 Buyurtma tafsilotini yozing.',
      quantity: '🔢 Miqdorni kiriting.',
      amount: '💰 Kelishilgan summani yuboring.',
    };

    await ctx.reply(prompts[field] || 'Kerakli ma’lumotni yuboring.');
    return ctx.wizard.next();
  },
  async (ctx) => {
    if (ctx.message?.text === '❌ Bekor qilish') {
      await ctx.reply('Buyurtma bekor qilindi.', userMainKeyboard(isAdmin(ctx)));
      return ctx.scene.leave();
    }

    if (!ctx.message?.text) {
      await ctx.reply('Iltimos, matn ko‘rinishida ma’lumot yuboring.');
      return;
    }

    const field = ctx.scene.state.fields[ctx.scene.state.currentFieldIndex];
    const value = safeText(ctx.message.text);

    if (field === 'username' && !validateUsername(value)) {
      await ctx.reply('Username noto‘g‘ri. Masalan: @username');
      return;
    }

    if (field === 'link' && !validateLink(value)) {
      await ctx.reply('Link noto‘g‘ri kiritildi.');
      return;
    }

    if (field === 'quantity' && !validateQuantity(value)) {
      await ctx.reply('Miqdor faqat raqam bo‘lishi kerak.');
      return;
    }

    if (field === 'amount' && !validateAmount(value)) {
      await ctx.reply('Summa noto‘g‘ri kiritildi.');
      return;
    }

    ctx.scene.state.responses[field] = field === 'link' ? normalizeLink(value) : value;
    ctx.scene.state.currentFieldIndex += 1;

    if (ctx.scene.state.currentFieldIndex < ctx.scene.state.fields.length) {
      const nextField = ctx.scene.state.fields[ctx.scene.state.currentFieldIndex];
      const prompts = {
        username: '👤 Username yuboring.',
        link: '🔗 Link yuboring.',
        note: '📝 Tafsilotni yozing.',
        quantity: '🔢 Miqdorni kiriting.',
        amount: '💰 Summani kiriting.',
      };
      await ctx.reply(prompts[nextField] || 'Keyingi ma’lumotni yuboring.');
      return;
    }

    const service = ctx.scene.state.service;
    const dynamicAmount = Number(service.price) > 0 ? Number(service.price) : 0;
    ctx.scene.state.amount = dynamicAmount;

    let summary = `📋 Buyurtma yakuni:\n\n`;
    summary += `📦 Xizmat: ${service.title}\n`;
    summary += `💰 Narx: ${dynamicAmount > 0 ? formatPrice(dynamicAmount) : 'Kelishiladi'}\n`;
    summary += `⏱ Muddat: ${service.delivery_time || '-'}\n\n`;
    summary += `${formatOrderDetails(ctx.scene.state.responses)}\n\n`;

    if (dynamicAmount > 0) {
      summary += 'Davom etish uchun pastdagi tugmani bosing.';
      await ctx.reply(summary, {
        reply_markup: Markup.inlineKeyboard([
          [Markup.button.callback('➡️ To‘lovga o‘tish', 'CONTINUE_TO_PAYMENT')],
          [Markup.button.callback('❌ Bekor qilish', 'CANCEL_ORDER_SCENE')],
        ]).reply_markup,
      });
      return ctx.wizard.next();
    }

    summary += 'Bu xizmat uchun narx admin bilan kelishiladi. Buyurtmani yuborishni xohlaysizmi?';
    await ctx.reply(summary, {
      reply_markup: Markup.inlineKeyboard([
        [Markup.button.callback('✅ Buyurtmani yuborish', 'SUBMIT_FREEFORM_ORDER')],
        [Markup.button.callback('❌ Bekor qilish', 'CANCEL_ORDER_SCENE')],
      ]).reply_markup,
    });

    return ctx.wizard.selectStep(4);
  },
  async (ctx) => {
    if (ctx.callbackQuery?.data?.startsWith('ORDER_METHOD_')) {
      const methodId = Number(ctx.callbackQuery.data.replace('ORDER_METHOD_', ''));
      const method = findPaymentMethodById(methodId);

      if (!method || Number(method.is_active) !== 1) {
        await ctx.answerCbQuery('To‘lov usuli topilmadi.');
        return;
      }

      ctx.scene.state.selectedMethod = method;
      ctx.scene.state.payerName = ctx.from?.username ? `@${ctx.from.username}` : (ctx.from?.first_name || 'User');

      await ctx.answerCbQuery();
      const text = `💳 ${method.title}\n\n${method.details}\n\n💰 To‘lov miqdori: ${formatPrice(ctx.scene.state.amount)}\n\n📸 To‘lov cheki rasmini yuboring.`;
      try {
        await ctx.editMessageText(text);
      } catch {
        await ctx.reply(text);
      }
      await ctx.reply('📸 Chek rasmini yuboring.', Markup.keyboard([['❌ Bekor qilish']]).resize());
      return ctx.wizard.next();
    }
  },
  async (ctx) => {
    if (ctx.message?.text === '❌ Bekor qilish') {
      await ctx.reply('Buyurtma bekor qilindi.', userMainKeyboard(isAdmin(ctx)));
      return ctx.scene.leave();
    }

    if (!ctx.message?.photo) {
      await ctx.reply('Iltimos, to‘lov cheki rasmini yuboring.');
      return;
    }

    const fileId = ctx.message.photo[ctx.message.photo.length - 1].file_id;
    const service = ctx.scene.state.service;
    const orderId = nextId('orders');
    const paymentId = nextId('payments');
